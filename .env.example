# Variables de entorno (frontend, Vite)
# Copia este archivo a .env y rellena VITE_API_BASE con la URL de tu backend.
#
# En local (sin .env) la app usa http://<hostname>:5001/api automáticamente.
# En producción (GitHub Pages + Render) se inyecta VITE_API_BASE vía repo secret.
VITE_API_BASE=https://kavana-routefleet-api.onrender.com
